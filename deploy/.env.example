# =============================================================================
# Corevision API - Variables d'environnement
# Copier vers /opt/corevision-api/.env et remplir les valeurs
# =============================================================================

NODE_ENV=production

# Chemins données (ne pas changer sauf si tu modifies setup-vps.sh)
DATA_DIR=/opt/corevision/data
UPLOADS_DIR=/opt/corevision/uploads

# JWT - GÉNÉRER AVEC : openssl rand -hex 32
JWT_SECRET=REMPLACER_PAR_UNE_CLE_SECRETE_DE_64_CHARS_MINIMUM

# Port du serveur Hono (Nginx proxifie vers ce port)
PORT=3000

# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct

# URL publique de l'API (utilisée pour les signed URLs des fichiers)
API_BASE_URL=https://api.corevision.fr

# Brevo (emails) - OPTIONNEL, garder si tu utilises les mails
BREVO_API_KEY=REMPLACER_PAR_CLE_BREVO

# Qdrant (local - optionnel pour la phase 1)
QDRANT_URL=http://localhost:6333
