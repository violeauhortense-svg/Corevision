s\":\"required\",\"requiredForStage\":\"R1\"},{\"id\":\"r7\",\"name\":\"Mail compte rendu + bilan\",\"status\":\"uploaded\",\"requiredForStage\":\"R1-R2\",\"uploadDate\":\"16/02/2026\",\"uploadedFile\":{\"id\":\"mail-bilan-1771244173320\",\"name\":\"Email de compte rendu envoyé\",\"type\":\"Email\",\"size\":\"-\",\"uploadDate\":\"16/02/2026\",\"category\":\"regulatory\",\"isEmailCopy\":true,\"emailData\":{\"subject\":\"Compte rendu de notre rendez-vous - Bilan patrimonial à signer\",\"intro\":\"Suite à notre rendez-vous, je vous transmets votre bilan patrimonial complet.\",\"body\":\"Ce document récapitule votre situation patrimoniale actuelle et constitue la base de notre accompagnement.\\n\\nMerci de prendre connaissance de ce bilan et de le signer électroniquement en cliquant sur le lien ci-dessous.\",\"closing\":\"Si vous avez des questions, n'hésitez pas à me contacter.\",\"sentTo\":\"violeau.hortense@gmail.com\",\"sentBy\":\"Votre Conseiller\",\"sentFrom\":\"contact@cvh-patrimoine.com\",\"sentAt\":\"2026-02-16T12:16:13.320Z\",\"clientName\":\"violeau hortense\",\"signatureUrl\":\"https://jaw-karate-78155897.figma.site/?page=sign-bilan&token=429787c3-0081-4fd6-8b4a-38a07717875a\"}}},{\"id\":\"r8\",\"name\":\"Lettre de mission\",\"status\":\"required\",\"requiredForStage\":\"R1-R2\"},{\"id\":\"r9\",\"name\":\"Mandat de recherche IAS\",\"status\":\"required\",\"requiredForStage\":\"R1-R2\"},{\"id\":\"r10\",\"name\":\"Audit patrimonial signé\",\"status\":\"required\",\"requiredForStage\":\"R2\"},{\"id\":\"r11\",\"name\":\"Rapport d'adéquation signé\",\"status\":\"required\",\"requiredForStage\":\"R2\"},{\"id\":\"r12\",\"name\":\"Copie du dossier de souscription produit\",\"status\":\"required\",\"requiredForStage\":\"R2\"}],\"clientTasks\":[{\"id\":\"task-7a1b0dcf-b181-44c8-a031-bb46e12f4f90-R1-0\",\"title\":\"Envoi du compte rendu de RDV 1\",\"completed\":true,\"createdAt\":\"2026-02-16T12:16:09.191Z\",\"clientId\":\"7a1b0dcf-b181-44c8-a031-bb46e12f4f90\",\"clien