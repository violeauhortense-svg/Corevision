clientId\":\"1aed7455-1e01-480a-a36f-1db3cb33914d\",\"clientName\":\"hortense violeau\",\"client_id\":\"1aed7455-1e01-480a-a36f-1db3cb33914d\",\"conseiller_id\":\"0b0d7613-ba71-45ce-9192-1a8817905a05\"}],\"auditRecommendations\":[],\"objectifs\":[{\"id\":\"obj-1\",\"categorie\":\"Socle – Diagnostic patrimonial\",\"description\":\"Analyse civile (famille, régime matrimonial, objectifs), analyse fiscale IR, simulation successorale à situation actuelle, lecture actif/passif, identification des enjeux. Ne comprend pas de stratégie chiffrée ni scénario.\",\"inclus\":true,\"obligatoire\":true},{\"id\":\"obj-2\",\"categorie\":\"Patrimoine financier\",\"description\":\"Analyse allocation actuelle, cohérence risque/horizon, structuration des enveloppes, identification arbitrages stratégiques (sans recommandation produit).\",\"inclus\":false,\"obligatoire\":false},{\"id\":\"obj-3\",\"categorie\":\"Objectif : acquisition RP / investissement immobilier\",\"description\":\"Capacité financière, arbitrages financiers, interaction fiscalité/endettement, faisabilité patrimoniale.\",\"inclus\":false,\"obligatoire\":false},{\"id\":\"obj-4\",\"categorie\":\"Objectif : constitution / optimisation épargne financière\",\"description\":\"Allocation cible, structuration enveloppes, cohérence objectif / risque / horizon, arbitrages stratégiques.\",\"inclus\":false,\"obligatoire\":false},{\"id\":\"obj-5\",\"categorie\":\"Objectif : retraite (particulier)\",\"description\":\"Estimation besoins futurs, analyse droits existants, stratégie effort épargne, articulation fiscale.\",\"inclus\":false,\"obligatoire\":false},{\"id\":\"obj-6\",\"categorie\":\"Objectif : transmission / succession\",\"description\":\"Analyse successorale approfondie, stratégies civiles/fiscales, schémas de transmission, points de vigilance.\",\"inclus\":false,\"obligatoire\":false},{\"id\":\"obj-7\",\"categorie\":\"Dirigeant – société simple (SASU, EURL, TNS)\",\"description\":\"Analyse statut dirigeant, rémunération/divid