{
  "imports": {
    "hono": "npm:hono@^4.12",
    "hono/cors": "npm:hono/cors",
    "hono/logger": "npm:hono/logger",
    "@db/sqlite": "jsr:@db/sqlite@^0.12"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read=/opt/corevision --allow-write=/opt/corevision --allow-env index.tsx",
    "dev": "deno run --allow-net --allow-read --allow-write --allow-env --watch index.tsx"
  },
  "lint": {
    "rules": { "exclude": ["no-explicit-any"] }
  }
}
