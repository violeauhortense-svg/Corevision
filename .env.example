# ============================================================================
# CoreVision - Environment Variables
# Copy to .env (frontend) or configure in Render dashboard (backend)
# ============================================================================

# FRONTEND (Vercel)
# No env vars needed - configuration in vercel.json

# BACKEND (Render)
# ============================================================================

# Database (PostgreSQL on Render)
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-minimum-32-characters

# OpenAI (GPT-4o for AI features)
OPENAI_API_KEY=sk-your-key-here

# Environment
NODE_ENV=production

# File Storage
UPLOADS_DIR=/opt/corevision/uploads

# API Base URL (for signed URLs, file downloads, etc.)
API_BASE_URL=https://corevision-api.onrender.com

# Optional: Email service
BREVO_API_KEY=optional-if-using-emails
